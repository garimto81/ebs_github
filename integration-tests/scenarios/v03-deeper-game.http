#   - pot.main === 0

# ──────────────────────────────────────────────────────────────────────
# Phase G: v02 baseline 회귀 — /next-hand rotation
# ──────────────────────────────────────────────────────────────────────

### G.1 POST event — hand_end (Engine 자동 회전)
POST {{engine}}/api/session/{{v01Regression.response.body.sessionId}}/event
Content-Type: application/json

{ "type": "hand_end" }

# Assertion (v02 동일):
#   - handNumber === 1
#   - dealerSeat === 1

### G.2 POST /next-hand — v02 회귀
POST {{engine}}/api/session/{{v01Regression.response.body.sessionId}}/next-hand

# Assertion (v02 동일 + v03 신규 키):
#   - handNumber === 2
#   - dealerSeat === 2
#   - sbSeat === 3 (v03 NEW key)
#   - bbSeat === 4 (v03 NEW key)
#   - 모든 seats[].currentBet === 0
#   - 모든 seats[].status === active (folded → active 복귀)
#   - pot.main === 0

# ──────────────────────────────────────────────────────────────────────
# Phase H: v03 4-hand round-robin straddle wrap-around (Multi_Hand_v03.md §1.4)
#
# 6-seat 에서 straddleSeat 가 wrap-around 4회 발생하는지 검증.
# hand 1 straddle=3 → hand 2 = 4 → hand 3 = 5 → hand 4 = 0 (wrap)
# ──────────────────────────────────────────────────────────────────────

### H.1 POST /api/session — straddle 활성 (wrap-around 검증 전용)
# @name roundRobinSession
POST {{engine}}/api/session
Content-Type: application/json

{
  "variant": "nlh",
  "seatCount": 6,
  "config": {
    "straddleEnabled": true,
    "straddleSeat": 3
  }
}

### H.2 POST /next-hand × 1 — straddle=3 → 4
POST {{engine}}/api/session/{{roundRobinSession.response.body.sessionId}}/next-hand

# Assertion: straddleSeat === 4

### H.3 POST /next-hand × 2 — straddle=4 → 5
POST {{engine}}/api/session/{{roundRobinSession.response.body.sessionId}}/next-hand

# Assertion: straddleSeat === 5

### H.4 POST /next-hand × 3 — straddle=5 → 0 (WRAP)
POST {{engine}}/api/session/{{roundRobinSession.response.body.sessionId}}/next-hand

# Assertion (Multi_Hand_v03.md §1.4):
#   - straddleSeat === 0 (5 → 0 wrap-around)
#   - dealerSeat === 3

### H.5 POST /next-hand × 4 — straddle=0 → 1
POST {{engine}}/api/session/{{roundRobinSession.response.body.sessionId}}/next-hand

# Assertion:
#   - straddleSeat === 1
#   - dealerSeat === 4
#   - handNumber === 4

# ──────────────────────────────────────────────────────────────────────
# Phase I: Final DoD cumulative
# ──────────────────────────────────────────────────────────────────────

