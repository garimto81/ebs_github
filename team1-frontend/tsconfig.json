{
  "extends": "./.quasar/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "types": ["vite/client", "vitest/globals", "quasar", "node"],
    "baseUrl": ".",
    "paths": {
      "src/*": ["src/*"],
      "app/*": ["./*"],
      "components/*": ["src/components/*"],
      "layouts/*": ["src/layouts/*"],
      "pages/*": ["src/pages/*"],
      "assets/*": ["src/assets/*"],
      "stores/*": ["src/stores/*"],
      "api/*": ["src/api/*"]
    }
  },
  "include": [
    "src/**/*",
    "src-*/**/*",
    "test/**/*",
    "e2e/**/*",
    ".quasar/**/*",
    "quasar.config.js"
  ],
  "exclude": ["dist", "node_modules", "src-capacitor", "src-cordova"]
}
