{
  "name": "team1-frontend",
  "version": "0.1.0",
  "description": "EBS Team 1 — Lobby + Settings + Graphic Editor hub (Quasar + Vue 3)",
  "productName": "EBS Lobby",
  "author": "EBS Team 1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.12",
    "@rive-app/canvas": "^2.21.0",
    "axios": "^1.7.7",
    "pinia": "^2.2.4",
    "quasar": "^2.16.0",
    "vue": "^3.5.0",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.6",
    "@playwright/test": "^1.48.0",
    "@quasar/app-vite": "^2.0.0",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.12.0",
    "@typescript-eslint/parser": "^8.12.0",
    "@vitest/coverage-v8": "^2.1.4",
    "@vue/eslint-config-typescript": "^14.1.3",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.30.0",
    "jsdom": "^25.0.1",
    "msw": "^2.6.0",
    "prettier": "^3.3.3",
    "typescript": "~5.6.3",
    "vite": "~5.4.0",
    "vite-plugin-checker": "^0.8.0",
    "vitest": "^2.1.4",
    "vue-tsc": "^2.1.10"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.3"
}
