{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/pre_push_drift_check.py"}
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {"type": "command", "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/file_lock_preedit.py"}
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/post_build_fail.py"}
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {"type": "command", "command": "python ${CLAUDE_PROJECT_DIR}/.claude/hooks/conductor_stop_cleanup.py"}
        ]
      }
    ]
  }
}