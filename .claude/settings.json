{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {"type": "command", "command": "python .claude/hooks/session_branch_init.py"},
          {"type": "command", "command": "python .claude/hooks/active_edits_session_start.py"}
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "python .claude/hooks/branch_guard.py"}
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {"type": "command", "command": "python .claude/hooks/active_edits_preedit.py"}
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {"type": "command", "command": "python .claude/hooks/active_edits_session_end.py"}
        ]
      }
    ]
  }
}
