{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "version": "6.1",
  "previous_version": 6,
  "description": "EBS 5팀 멀티 세션 충돌 방지 + v10 문서 구조. v6: 거버넌스 모델 명시 (free_write_with_decision_owner) — 쓰기 권한 폐지(누구나 모든 docs 편집 가능), 단 의미적 충돌 시 decision_owner가 최종 판정. 기존 owns/contract_ownership는 decision_owner 매핑으로 재해석(키는 호환 유지). branch_strategy 추가. v6.1: 기획 공백(spec gap) 프로세스를 '해당 기획 문서 즉시 보강' 방식으로 확정. Spec_Gaps.md · CR draft · CCR-first 프로세스 폐지. teams.*.ccr_draft_prefix 필드 제거.",
  "governance_model": {
    "name": "free_write_with_decision_owner",
    "rationale": "문서 구조 일원화 + 자유 편집 + 작업 시작 시 active-edit 레지스트리 가시화 + 머지 충돌 시 명시된 decision_owner가 의미적 결정. 쓰기 권한 ≠ 결정 권한.",
    "write_access": "all_sessions_all_docs",
    "decision_authority_source": "teams[*].owns and contract_ownership[*].publisher",
    "conflict_resolution": {
      "syntactic": "merge_author_resolves",
      "semantic": "decision_owner_adjudicates",
      "escalation": "conductor"
    }
  },
  "branch_strategy": {
    "main_push_allowed_for": ["conductor"],
    "team_branch_pattern": "work/{team}/{YYYYMMDD}-{slug}",
    "registry_branch": "meta/active-edits",
    "merge_method": "rebase_then_fast_forward",
    "merge_tool": "tools/team_merge.py"
  },
  "teams": {
    "conductor": {
      "cwd_match": null,
      "owns": [
        "docs/1. Product/",
        "docs/2. Development/2.5 Shared/",
        "docs/3. Change Requests/in-progress/",
        "docs/3. Change Requests/done/",
        "docs/3. Change Requests/3. Change Requests.md",
        "docs/4. Operations/",
        "docs/mockups/",
        "docs/images/",
        "docs/README.md",
        "contracts/migration/",
        "contracts/_templates/",
        "integration-tests/",
        "tools/",
        "CLAUDE.md",
        "README.md",
        ".gitignore",
        ".claude/"
      ],
      "backlog_file": "docs/4. Operations/Conductor_Backlog.md"
    },
    "team1": {
      "cwd_match": ["team1-frontend"],
      "owns": [
        "team1-frontend/",
        "docs/2. Development/2.1 Frontend/"
      ],
      "backlog_file": "docs/2. Development/2.1 Frontend/Backlog.md",
      "reads": [
        "docs/2. Development/2.2 Backend/APIs/",
        "docs/2. Development/2.3 Game Engine/APIs/",
        "docs/2. Development/2.4 Command Center/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/"
      ],
      "api_subscribes": ["Backend_HTTP", "WebSocket_Events", "Auth_and_Session"]
    },
    "team2": {
      "cwd_match": ["team2-backend"],
      "owns": [
        "team2-backend/",
        "docs/2. Development/2.2 Backend/"
      ],
      "backlog_file": "docs/2. Development/2.2 Backend/Backlog.md",
      "reads": [
        "docs/2. Development/2.3 Game Engine/APIs/",
        "docs/2. Development/2.4 Command Center/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/"
      ],
      "api_publishes": ["Backend_HTTP", "WebSocket_Events", "Auth_and_Session", "Graphic_Editor_API"]
    },
    "team3": {
      "cwd_match": ["team3-engine"],
      "owns": [
        "team3-engine/",
        "ebs_game_engine/",
        "docs/2. Development/2.3 Game Engine/"
      ],
      "backlog_file": "docs/2. Development/2.3 Game Engine/Backlog.md",
      "reads": [
        "docs/2. Development/2.2 Backend/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/Game_Rules/"
      ],
      "api_publishes": ["Overlay_Output_Events"]
    },
    "team4": {
      "cwd_match": ["team4-cc"],
      "owns": [
        "team4-cc/",
        "docs/2. Development/2.4 Command Center/"
      ],
      "backlog_file": "docs/2. Development/2.4 Command Center/Backlog.md",
      "reads": [
        "docs/2. Development/2.2 Backend/APIs/",
        "docs/2. Development/2.3 Game Engine/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/"
      ],
      "api_subscribes": ["Overlay_Output_Events", "WebSocket_Events"],
      "api_publishes": ["RFID_HAL"]
    }
  },
  "shared_blocked_for_teams": [
    "docs/1. Product/",
    "docs/2. Development/2.5 Shared/",
    "docs/3. Change Requests/in-progress/",
    "docs/3. Change Requests/done/",
    "docs/4. Operations/",
    "contracts/migration/",
    "integration-tests/",
    "CLAUDE.md",
    "README.md",
    "tools/"
  ],
  "ccr_inbox_dir": "docs/3. Change Requests/pending/",
  "ccr_in_progress_dir": "docs/3. Change Requests/in-progress/",
  "ccr_done_dir": "docs/3. Change Requests/done/",
  "generated_dir": "docs/_generated/",
  "api_dependencies": {
    "Backend_HTTP": ["team2", "team1"],
    "WebSocket_Events": ["team2", "team1", "team3", "team4"],
    "Auth_and_Session": ["team2", "team1"],
    "Overlay_Output_Events": ["team3", "team4"],
    "RFID_HAL": ["team4", "team1"],
    "Graphic_Editor_API": ["team2", "team1", "team4"]
  },
  "audit_log_path": ".claude/logs/scope-guard-{YYYYMMDD}.jsonl",
  "contract_ownership": {
    "docs/2. Development/2.2 Backend/APIs/Backend_HTTP.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team4"],
      "direct_edit": "LOW",
      "legacy_id": "API-01"
    },
    "docs/2. Development/2.2 Backend/APIs/WebSocket_Events.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team3", "team4"],
      "direct_edit": "LOW",
      "legacy_id": "API-05"
    },
    "docs/2. Development/2.2 Backend/APIs/Auth_and_Session.md": {
      "publisher": "team2",
      "subscribers": ["team1"],
      "direct_edit": "LOW",
      "legacy_id": "API-06"
    },
    "docs/2. Development/2.2 Backend/APIs/Graphic_Editor_API.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team4"],
      "direct_edit": "LOW",
      "legacy_id": "API-07"
    },
    "docs/2. Development/2.2 Backend/Database/Schema.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team3", "team4"],
      "direct_edit": "MEDIUM",
      "legacy_id": "DATA-04"
    },
    "docs/2. Development/2.2 Backend/Database/ER_Diagram.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team3", "team4"],
      "direct_edit": "LOW",
      "legacy_id": "DATA-01"
    },
    "docs/2. Development/2.2 Backend/Back_Office/Sync_Protocol.md": {
      "publisher": "team2",
      "subscribers": ["team1"],
      "direct_edit": "MEDIUM",
      "legacy_id": "BO-02"
    },
    "docs/2. Development/2.3 Game Engine/APIs/Overlay_Output_Events.md": {
      "publisher": "team3",
      "subscribers": ["team4"],
      "direct_edit": "LOW",
      "legacy_id": "API-04"
    },
    "docs/2. Development/2.4 Command Center/APIs/RFID_HAL.md": {
      "publisher": "team4",
      "subscribers": ["team1"],
      "direct_edit": "LOW",
      "legacy_id": "BS-04-04"
    }
  },
  "scope_guard_version": "v5",
  "scope_guard_env_var": "EBS_SCOPE_GUARD_VERSION",
  "scope_guard_rollback_value": "v4"
}
