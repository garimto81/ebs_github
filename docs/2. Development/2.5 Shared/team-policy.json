{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "version": "7.1",
  "previous_version": "7.0",
  "description": "EBS 5팀 멀티 세션 충돌 방지 + v11 문서 구조. v7.1 Mode A/B + v8.0 governance freeze. 역사: docs/4. Operations/Reports/ 참조.",
  "governance_model": {
    "name": "free_write_with_decision_owner_or_conductor_full_authority",
    "rationale": "v7.1 (SG-024 cascade, 2026-04-27 사용자 B-Q5 ㉠ 채택): 단일 세션 모드 (Mode A) 에서 Conductor 가 decision_owner override 가능. 멀티세션 모드 (Mode B) 에서는 v7 모델 (decision_owner 권한 회복).",
    "modes": {
      "mode_a_single_session": {
        "trigger": "Conductor 세션 단독 활동 (다른 팀 세션 비활성)",
        "default_in_v7_1": true,
        "write_access": "all_paths",
        "decision_authority": "conductor_full_authority",
        "rationale": "사용자 B-Q5 ㉠ (2026-04-27) 채택. 단일 turn cascade 자율 진행 가능."
      },
      "mode_b_multi_session": {
        "trigger": "팀 세션 (team1~4) 활성화 시 자동 회복",
        "write_access": "all_sessions_all_docs",
        "decision_authority_source": "teams[*].owns and contract_ownership[*].publisher",
        "rationale": "v7 모델 그대로. 각 팀 세션의 decision_owner 권한 보호."
      }
    },
    "mode_a_limits": {
      "_comment": "Mode A 라도 Conductor 자율 금지 영역",
      "external_messaging": "vendor RFI/RFQ 외부 메일 발송 — 사용자 명시 필요",
      "destructive_system": "DB drop, prod 배포, 거대 dependency 변경 — 사용자 명시 필요",
      "git_config": "remote URL 변경 등 — 사용자 명시 필요",
      "user_intent_change": "SG-023 같은 큰 결정 — Conductor 자율 시도 금지",
      "user_memory_decisions": "사용자 본인 결정 메모 임의 폐기 금지"
    },
    "conflict_resolution": {
      "syntactic": "merge_author_resolves",
      "semantic_mode_a": "conductor_adjudicates",
      "semantic_mode_b": "decision_owner_adjudicates",
      "escalation": "user (사용자)"
    },
    "freeze": {
      "_comment": "v8.0 stable governance freeze (user decision 4A, 2026-04-28)",
      "until": "2026-05-28",
      "scope": "all_governance_changes",
      "exceptions": ["data_loss_emergency", "critical_security_fix"],
      "rationale": "1주 7 governance 버전 churn (v5.0→v5.1→v6.1→v7.1→v7.2→v7.5→v7.6) 차단. Phase 1-8 file cleanup 완주 보장. critic 보고서 P2 권고.",
      "decision_brief": "docs/4. Operations/Conductor_Backlog/v8-phase9-governance-decisions.md",
      "phase_1_8_cleanup_allowed": true,
      "_phase_1_8_note": "freeze 는 governance change (mode/policy/limit) 만 동결. file cleanup (deprecated 정리, 도구 압축, 문서 압축) 은 Phase 1-8 으로 진행 가능."
    }
  },
  "branch_strategy": {
    "version": "v5.0",
    "updated": "2026-04-21",
    "main_push_allowed_for": [],
    "_main_push_allowed_for_note": "v5.0: 직접 main push 전면 금지. 모든 팀 (Conductor 포함) PR 경로. v4.x 에서는 ['conductor'] 였음.",
    "team_branch_pattern": "work/{team}/{slug}",
    "worktree_layout": "sibling_dir",
    "worktree_path_pattern": "C:/claude/ebs-{team}-{slug}/",
    "subdir_mode": "forbidden",
    "_subdir_mode_note": "v5.0: subdir (C:/claude/ebs/team{N}-*/) 모드 금지. shared HEAD 오염 방지.",
    "registry_branch": "meta/active-edits",
    "merge_method": "squash_via_pr",
    "_merge_method_note": "v5.0: gh pr create --fill + auto-merge 라벨 → .github/workflows/pr-auto-merge.yml",
    "merge_tool": "tools/team_v5_merge.py",
    "merge_gate": ".github/workflows/pr-auto-merge.yml",
    "code_owners": ".github/CODEOWNERS",
    "free_tier_compat": true,
    "deprecated_tools": {
      "tools/team_merge.py": "v4.x direct ff-merge tool. v5.1+L4 (BLANK-3) 에서 active 부활 — 폐기 보류",
      "~/.claude/skills/team/scripts/team_merge_loop.py": "v4.0 user-global. project-local .claude/skills/team/ (v5.1) 이 대체 (2026-04-22 rename from team-v5)"
    }
  },
  "teams": {
    "conductor": {
      "cwd_match": null,
      "owns": [
        "docs/1. Product/",
        "docs/2. Development/2.5 Shared/",
        "docs/4. Operations/",
        "docs/mockups/",
        "docs/images/",
        "docs/README.md",
        "contracts/migration/",
        "contracts/_templates/",
        "integration-tests/",
        "tools/",
        "CLAUDE.md",
        "README.md",
        ".gitignore",
        ".claude/"
      ],
      "backlog_file": "docs/4. Operations/Conductor_Backlog.md"
    },
    "team1": {
      "cwd_match": ["team1-frontend"],
      "owns": [
        "team1-frontend/",
        "docs/2. Development/2.1 Frontend/"
      ],
      "backlog_file": "docs/2. Development/2.1 Frontend/Backlog.md",
      "reads": [
        "docs/2. Development/2.2 Backend/APIs/",
        "docs/2. Development/2.3 Game Engine/APIs/",
        "docs/2. Development/2.4 Command Center/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/"
      ],
      "api_subscribes": ["Backend_HTTP", "WebSocket_Events", "Auth_and_Session"]
    },
    "team2": {
      "cwd_match": ["team2-backend"],
      "owns": [
        "team2-backend/",
        "docs/2. Development/2.2 Backend/"
      ],
      "backlog_file": "docs/2. Development/2.2 Backend/Backlog.md",
      "reads": [
        "docs/2. Development/2.3 Game Engine/APIs/",
        "docs/2. Development/2.4 Command Center/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/"
      ],
      "api_publishes": ["Backend_HTTP", "WebSocket_Events", "Auth_and_Session", "Graphic_Editor_API"]
    },
    "team3": {
      "cwd_match": ["team3-engine"],
      "owns": [
        "team3-engine/",
        "ebs_game_engine/",
        "docs/2. Development/2.3 Game Engine/"
      ],
      "backlog_file": "docs/2. Development/2.3 Game Engine/Backlog.md",
      "reads": [
        "docs/2. Development/2.2 Backend/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/Game_Rules/"
      ],
      "api_publishes": ["Overlay_Output_Events"]
    },
    "team4": {
      "cwd_match": ["team4-cc"],
      "owns": [
        "team4-cc/",
        "docs/2. Development/2.4 Command Center/"
      ],
      "backlog_file": "docs/2. Development/2.4 Command Center/Backlog.md",
      "reads": [
        "docs/2. Development/2.2 Backend/APIs/",
        "docs/2. Development/2.3 Game Engine/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/"
      ],
      "api_subscribes": ["Overlay_Output_Events", "WebSocket_Events"],
      "api_publishes": ["RFID_HAL"]
    }
  },
  "shared_blocked_for_teams": [
    "docs/1. Product/",
    "docs/2. Development/2.5 Shared/",
    "docs/4. Operations/",
    "contracts/migration/",
    "integration-tests/",
    "CLAUDE.md",
    "README.md",
    "tools/"
  ],
  "generated_dir": "docs/_generated/",
  "api_dependencies": {
    "Backend_HTTP": ["team2", "team1"],
    "WebSocket_Events": ["team2", "team1", "team3", "team4"],
    "Auth_and_Session": ["team2", "team1"],
    "Overlay_Output_Events": ["team3", "team4"],
    "RFID_HAL": ["team4", "team1"],
    "Graphic_Editor_API": ["team2", "team1", "team4"]
  },
  "audit_log_path": ".claude/logs/scope-guard-{YYYYMMDD}.jsonl",
  "contract_ownership": {
    "docs/2. Development/2.2 Backend/APIs/Backend_HTTP.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team4"],
      "direct_edit": "LOW",
      "legacy_id": "API-01"
    },
    "docs/2. Development/2.2 Backend/APIs/WebSocket_Events.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team3", "team4"],
      "direct_edit": "LOW",
      "legacy_id": "API-05"
    },
    "docs/2. Development/2.2 Backend/APIs/Auth_and_Session.md": {
