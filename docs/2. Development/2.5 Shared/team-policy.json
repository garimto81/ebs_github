{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "version": "10.4",
  "description": "EBS 거버넌스 SSOT (v10.4 9-Session Matrix + Message Bus 통합, 2026-05-11). v10.3 위에 cross-cutting 4 stream(S9 QA / S10-A Gap Analysis / S10-W Gap Writing / S11 Dev Assist) + 옵션 SMEM 추가. 사용자 6 역할(orchestrator + dev + gap 분석 + gap 작성 + QA + 보조) × 8 도메인 매트릭스. message_bus broker(@7383) 의 pipeline:* prefix 가 단방향 흐름(gap→write→dev→qa) 연결. 멀티세션 spec = Multi_Session_Design_v11.md + team_assignment_v10_3.yaml(v10.4). 1주일 KPI: 빌드 0% → 1 hand 시나리오 50%.",
  "governance_model": {
    "name": "architect_then_observer_multi_session",
    "version": "v10.3",
    "rationale": "글로벌 orchestrator 스킬 v10.3 패턴 적용. Phase 0 사전 설계로 충돌 차단 + Phase 1+ Observer 모니터링. 사용자 진입점 = VSCode 폴더 클릭 1회 (Stream 진입). 이전 세대 phantom 도구 (conflict_resolver / session_branch_init / branch_guard / Mode 자동전환 / Conflict_Registry) 는 글로벌 v10.3 자산 (SessionStart.py / PreToolUse.py / Architect-then-Observer / GitHub Issue+PR 라벨) 으로 대체.",
    "intent_execution_boundary": {
      "_comment": "사용자 의도 영역 vs AI 자율 영역. SSOT 기반 판단 가능 영역은 AI 자율, 불가능 시 SSOT 보강이 정답.",
      "user_intent_domain": [
        "큰 방향성 / 패러다임 결정",
        "외부 visible action (vendor 메일, Slack 메시지, prod 배포)",
        "destructive 시스템 변경 (DB drop, git config, 거대 dependency)",
        "사용자 본인 결정 memory 변경",
        "본 governance_model 자체 변경 (self-bootstrap 방지)"
      ],
      "ai_execution_domain_with_ssot": [
        "SSOT 검색 + 분석 + 판단 (ssot_priority chain 따라)",
        "SSOT 모호 시 → SSOT 보강 PR 자율 생성 + 머지",
        "코드 / 문서 / 인프라 작성",
        "PR 생성 (draft → ready → auto-merge)",
        "충돌 해결 (Phase 0 사전 설계 또는 SSOT priority 기반)",
        "기술 가치 판단 (작업 보존/폐기, 머지 방식)"
      ],
      "user_intent_question_standard": {
        "forbidden_terms": [
          "worktree", "commit hash", "cherry-pick", "squash", "branch", "PR number", "merge", "rebase",
          "내부 식별자 (B-XXX, SG-XXX)", "scope_check", "self-bootstrap"
        ],
        "required_form": "배경 1줄 + 옵션 2~3개 + 영향 1줄. 평이한 한국어. 비전문 개발자 친화.",
        "test": "비전문 개발자가 사용 경험만으로 답할 수 있는가?"
      }
    },
    "operating_model": {
      "name": "architect_then_observer",
      "phase_0_architect": {
        "trigger": "사용자 의도 1회 (멀티세션 시작 또는 동적 추가 요청)",
        "duration": "최대 90분 자율",
        "outputs": [
          "Stream 매트릭스 (이미 정립된 EBS 는 자동 추론 스킵)",
          "워크트리 폴더 사전 세팅 (sibling-dir)",
          "각 워크트리: .team / CLAUDE.md / START_HERE.md / hook / .vscode/settings.json",
          "GitHub 인프라 (CODEOWNERS, branch-protection, ISSUE/PR_TEMPLATE, scope_check.yml, dependency_check.yml, phase_gate_check.yml)",
          "자가 시뮬 (SessionStart hook identity 검증)"
        ],
        "user_touchpoint": "Stream 매트릭스 검토 1회 (이미 정립된 EBS 는 스킵 가능)"
      },
      "phase_1_plus_observer": {
        "trigger": "Phase 0 완료 후 영구",
        "behavior": [
          "30초 GitHub 폴링 (orchestrator_monitor.py)",
          "Stream 의존성 unblock 자동",
          "Stream idle (24h+) escalate",
          "동적 Stream 추가 시 Architect 일시 전환"
        ]
      }
    },
    "merge_authority": {
      "stream_session_pr": {
        "creation": "tools/orchestrator/team_session_start.py (자동 GitHub Issue + Draft PR + 라벨)",
        "completion": "tools/orchestrator/team_session_end.py (auto-merge enabled, branch 자동 삭제)",
        "self_merge_conditions": [
          "AI 작성 PR",
          "CI all green",
          "merge conflict 없음",
          "scope_check 통과 또는 governance-change 라벨",
          "사용자 의도 trigger 와 정합"
        ]
      },
      "main_direct": {
        "allowed_for": ["conductor"],
        "scope": ["CLAUDE.md", "docs/", ".claude/"],
        "rationale": "Conductor 단독 활동 시 main 직접 수정 가능"
      },
      "user_consultation_required_when": [
        "다중 PR 의미적 충돌 (Phase 0 사전 설계로 차단되어야 정상)",
        "destructive 시스템 변경",
        "외부 visible state (vendor 메일, prod 배포)",
        "self-bootstrap (governance 자체 확장)"
      ]
    },
    "conflict_resolution": {
      "primary_strategy": "Phase 0 사전 설계로 충돌 차단 (Architect-then-Observer 핵심)",
      "fallback_when_conflict_occurs": {
        "syntactic": "Conductor 가 ssot_priority 기반 직접 rebase",
        "semantic": "ssot_priority chain 따라 판정 + 판정 불가 시 Spec_Gap 등재"
      },
      "ssot_priority": [
        "docs/1. Product/Foundation.md",
        "docs/2. Development/2.5 Shared/team-policy.json",
        "docs/2. Development/2.5 Shared/Risk_Matrix.md",
        "docs/2. Development/2.{2,3,4}/APIs/**",
        "docs/2. Development/2.*/Backlog/**"
      ],
      "global_v10_3_subsumption": "phantom 도구 (conflict_resolver.py / Conflict_Registry.md) 는 글로벌 v10.3 패턴 (Architect-then-Observer Phase 0 + GitHub Issue+PR 라벨 분산 audit) 으로 대체. 별도 도구 신규 구현 불필요."
    },
    "conductor_limits": {
      "external_messaging": "vendor RFI/RFQ 외부 메일 — 사용자 명시 필요",
      "destructive_system": "DB drop, prod 배포, 거대 dependency — 사용자 명시 필요",
      "git_config": "remote URL 등 — 사용자 명시 필요",
      "user_intent_change": "큰 방향성 결정 — Conductor 자율 시도 금지",
      "user_memory_decisions": "사용자 본인 결정 memory 임의 폐기 금지"
    }
  },
  "branch_strategy": {
    "main_push_allowed_for": ["conductor"],
    "_main_push_allowed_for_note": "Conductor 만 main 직접 push (governance/board/cleanup commit). Stream 세션은 PR 경로 (orchestrator team_session_start.py / team_session_end.py auto-merge).",
    "stream_branch_pattern": "work/{stream}/{slug}",
    "worktree_layout": "sibling_dir",
    "worktree_path_pattern": "C:/claude/ebs-{stream}/",
    "subdir_mode": "forbidden",
    "_subdir_mode_note": "subdir (C:/claude/ebs/team{N}-*/) 모드 금지. shared HEAD 오염 방지.",
    "merge_method": "stream_session_auto_merge_or_conductor_squash",
    "_merge_method_note": "Stream 세션 = orchestrator team_session_end.py (auto-merge, branch 삭제). Conductor 단일 활동 = main 직접 또는 squash merge.",
    "code_owners": ".github/CODEOWNERS",
    "free_tier_compat": true
  },
  "teams": {
    "conductor": {
      "cwd_match": null,
      "owns": [
        "docs/1. Product/",
        "docs/2. Development/2.5 Shared/",
        "docs/4. Operations/",
        "docs/mockups/",
        "docs/images/",
        "docs/README.md",
        "integration-tests/",
        "tools/",
        "CLAUDE.md",
        "README.md",
        ".gitignore",
        ".claude/"
      ],
      "backlog_file": "docs/4. Operations/Conductor_Backlog.md"
    },
    "team1": {
      "cwd_match": ["team1-frontend"],
      "owns": [
        "team1-frontend/",
        "docs/2. Development/2.1 Frontend/"
      ],
      "backlog_file": "docs/2. Development/2.1 Frontend/Backlog.md",
      "reads": [
        "docs/2. Development/2.2 Backend/APIs/",
        "docs/2. Development/2.3 Game Engine/APIs/",
        "docs/2. Development/2.4 Command Center/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/"
      ],
      "api_subscribes": ["Backend_HTTP", "WebSocket_Events", "Auth_and_Session"]
    },
    "team2": {
      "cwd_match": ["team2-backend"],
      "owns": [
        "team2-backend/",
        "docs/2. Development/2.2 Backend/"
      ],
      "backlog_file": "docs/2. Development/2.2 Backend/Backlog.md",
      "reads": [
        "docs/2. Development/2.3 Game Engine/APIs/",
        "docs/2. Development/2.4 Command Center/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/"
      ],
      "api_publishes": ["Backend_HTTP", "WebSocket_Events", "Auth_and_Session", "Graphic_Editor_API"]
    },
    "team3": {
      "cwd_match": ["team3-engine"],
      "owns": [
        "team3-engine/",
        "ebs_game_engine/",
        "docs/2. Development/2.3 Game Engine/"
      ],
      "backlog_file": "docs/2. Development/2.3 Game Engine/Backlog.md",
      "reads": [
        "docs/2. Development/2.2 Backend/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/Game_Rules/"
      ],
      "api_publishes": ["Overlay_Output_Events"]
    },
    "team4": {
      "cwd_match": ["team4-cc"],
      "owns": [
        "team4-cc/",
        "docs/2. Development/2.4 Command Center/"
      ],
      "backlog_file": "docs/2. Development/2.4 Command Center/Backlog.md",
      "reads": [
        "docs/2. Development/2.2 Backend/APIs/",
        "docs/2. Development/2.3 Game Engine/APIs/",
        "docs/2. Development/2.5 Shared/",
        "docs/1. Product/"
      ],
      "api_subscribes": ["Overlay_Output_Events", "WebSocket_Events"],
      "api_publishes": ["RFID_HAL"]
    },
    "_comment_cross_cutting": "v10.4 — cross-cutting streams (S9/S10-A/S10-W/S11/SMEM). 도메인 4팀(team1~4)을 가로지르며 pipeline:* broker topic 으로 단방향 흐름.",
    "S9": {
      "cwd_match": ["ebs-qa"],
      "owns": [
        "integration-tests/",
        ".github/workflows/team-e2e.yml"
      ],
      "reads": [
        "docs/1. Product/",
        "docs/2. Development/",
        "team1-frontend/", "team2-backend/", "team3-engine/", "team4-cc/"
      ],
      "broker_publish": ["stream:S9", "pipeline:qa-pass", "pipeline:qa-fail", "cascade:*", "defect:*", "audit:*"],
      "broker_subscribe": ["pipeline:build-success", "cascade:*", "*"]
    },
    "S10-A": {
      "cwd_match": ["ebs-gap-audit"],
      "owns": [
        "docs/4. Operations/Spec_Gap_Registry.md",
        "tools/spec_drift_check.py"
      ],
      "reads": [
        "docs/1. Product/",
        "docs/2. Development/",
        "integration-tests/",
        "docs/4. Operations/Spec_Gap_Triage.md"
      ],
      "broker_publish": ["stream:S10-A", "pipeline:gap-classified", "cascade:*", "defect:*", "audit:*"],
      "broker_subscribe": ["pipeline:qa-fail", "cascade:build-fail", "*"]
    },
    "S10-W": {
      "cwd_match": ["ebs-gap-write"],
      "owns": [
        "docs/4. Operations/Conductor_Backlog/_template_spec_gap*.md"
      ],
      "reads": [
        "docs/1. Product/",
        "docs/2. Development/",
        "docs/4. Operations/Spec_Gap_Registry.md"
      ],
      "_owns_note": "PRD 본문(docs/1. Product/*_PRD.md)은 도메인 owner 가 머지 권한, S10-W 는 PR 발행만 가능 (acquire_lock ttl=300 필수)",
      "broker_publish": ["stream:S10-W", "pipeline:spec-patched", "cascade:*", "audit:*"],
      "broker_subscribe": ["pipeline:gap-classified", "*"],
      "blocked_by": ["S10-A"]
    },
    "S11": {
      "cwd_match": ["ebs-devops"],
      "owns": [
        "docs/4. Operations/Docker_Runtime.md",
        "docker-compose.yml"
      ],
      "reads": [
        "docs/4. Operations/",
        "team1-frontend/docker-compose.yml",
        "team2-backend/docker-compose.yml",
        "team3-engine/docker-compose.yml",
        "team4-cc/docker-compose.yml"
      ],
      "_owns_note": "root docker-compose.yml 만 직접 편집. 도메인 compose 는 read-only 감사.",
      "broker_publish": ["stream:S11", "pipeline:env-ready", "pipeline:env-broken", "cascade:*", "audit:*"],
      "broker_subscribe": ["cascade:build-fail", "pipeline:build-fail", "*"]
    },
    "SMEM": {
      "cwd_match": ["ebs-memory"],
      "owns": [],
      "_owns_note": "append-only via PR — exclusive scope 없음. MEMORY.md 는 conductor 와 공유 owner.",
      "reads": ["**/*"],
      "broker_publish": ["audit:memory-snapshot", "audit:memory-rotate"],
      "broker_subscribe": ["*"],
      "optional": true
    }
  },
  "shared_blocked_for_teams": [
    "docs/1. Product/",
    "docs/2. Development/2.5 Shared/",
    "docs/4. Operations/",
    "integration-tests/",
    "CLAUDE.md",
    "README.md",
    "tools/"
  ],
  "generated_dir": "docs/_generated/",
  "api_dependencies": {
    "Backend_HTTP": ["team2", "team1"],
    "WebSocket_Events": ["team2", "team1", "team3", "team4"],
    "Auth_and_Session": ["team2", "team1"],
    "Overlay_Output_Events": ["team3", "team4"],
    "RFID_HAL": ["team4", "team1"],
    "Graphic_Editor_API": ["team2", "team1", "team4"]
  },
  "audit_log_path": ".claude/logs/scope-guard-{YYYYMMDD}.jsonl",
  "contract_ownership": {
    "docs/2. Development/2.2 Backend/APIs/Backend_HTTP.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team4"],
      "direct_edit": "LOW",
      "legacy_id": "API-01"
    },
    "docs/2. Development/2.2 Backend/APIs/WebSocket_Events.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team3", "team4"],
      "direct_edit": "LOW",
      "legacy_id": "API-05"
    },
    "docs/2. Development/2.2 Backend/APIs/Auth_and_Session.md": {
      "publisher": "team2",
      "subscribers": ["team1"],
      "direct_edit": "LOW",
      "legacy_id": "API-06"
    },
    "docs/2. Development/2.2 Backend/APIs/Graphic_Editor_API.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team4"],
      "direct_edit": "LOW",
      "legacy_id": "API-07"
    },
    "docs/2. Development/2.2 Backend/Database/Schema.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team3", "team4"],
      "direct_edit": "MEDIUM",
      "legacy_id": "DATA-04"
    },
    "docs/2. Development/2.2 Backend/Database/ER_Diagram.md": {
      "publisher": "team2",
      "subscribers": ["team1", "team3", "team4"],
      "direct_edit": "LOW",
      "legacy_id": "DATA-01"
    },
    "docs/2. Development/2.2 Backend/Back_Office/Sync_Protocol.md": {
      "publisher": "team2",
      "subscribers": ["team1"],
      "direct_edit": "MEDIUM",
      "legacy_id": "BO-02"
    },
    "docs/2. Development/2.3 Game Engine/APIs/Overlay_Output_Events.md": {
      "publisher": "team3",
      "subscribers": ["team4"],
      "direct_edit": "LOW",
      "legacy_id": "API-04"
    },
    "docs/2. Development/2.4 Command Center/APIs/RFID_HAL.md": {
      "publisher": "team4",
      "subscribers": ["team1"],
      "direct_edit": "LOW",
      "legacy_id": "BS-04-04"
    }
  },
  "scope_guard_version": "v5",
  "scope_guard_env_var": "EBS_SCOPE_GUARD_VERSION",
  "scope_guard_rollback_value": "v4"
}
