  "audio_layers": [
    {"event": "card_dealt", "file": "assets/audio/card-flip.ogg", "volume": 0.8},
    {"event": "chip_bet", "file": "assets/audio/chip-push.ogg", "volume": 0.6},
    {"event": "showdown", "file": "assets/audio/sting.ogg", "volume": 1.0}
