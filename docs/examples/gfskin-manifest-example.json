  "$schema": "https://ebs.local/schemas/gfskin-manifest-v1.json",
  "spec_version": "1.0",
  "skin_id": "01234567-89ab-4cdef-0123-456789abcdef",
  "name": {
    "ko": "기본 스킨",
    "en": "Default Skin",
    "es": "Tema Predeterminado"
  },
  "version": "1.0.0",
