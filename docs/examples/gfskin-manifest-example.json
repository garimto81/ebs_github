  "element_mapping": {
    "holecards": "layer:holecards_group",
    "community": "layer:community_cards",
    "pot": "text:pot_value",
    "side_pot": "text:side_pot_value",
    "equity": "text:equity_percent",
    "outs": "text:outs_count",
