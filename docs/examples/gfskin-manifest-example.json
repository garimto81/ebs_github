  "rive_artboard": "MainOverlay",
  "supported_output_events": [
    "holecards_revealed",
    "holecards_hidden",
    "community_board_updated",
    "pot_updated",
    "equity_updated",
    "action_badge",
    "player_info_updated",
    "position_indicator",
    "outs_updated",
    "hand_start",
    "hand_end",
    "showdown_reveal"
